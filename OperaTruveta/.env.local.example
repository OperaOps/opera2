# OperaTruveta — Patient Education Studio
# Copy to .env.local and fill in to enable premium ElevenLabs narration.
# Without these, the player falls back to the browser's built-in speech voice.

# ElevenLabs text-to-speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=
# Optional — defaults to Rachel (calm female). Override with any ElevenLabs voice id.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional — defaults to eleven_turbo_v2_5 (fast, low-latency).
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
